# ============================================
# Vertech Agents — Environment Template
# ============================================
# Copy to .env.local and fill with real values
# ============================================

# --------------------------------------------
# Database (Supabase)
# --------------------------------------------
# Transaction pooler (runtime)
DATABASE_URL="postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres"
# Direct connection (migrations)
DIRECT_URL="postgresql://postgres:[password]@db.[ref].supabase.co:5432/postgres"

# --------------------------------------------
# Supabase Client (Storage, Realtime)
# --------------------------------------------
SUPABASE_URL="https://[ref].supabase.co"
SUPABASE_ANON_KEY=""
SUPABASE_SERVICE_ROLE_KEY=""

# --------------------------------------------
# Better Auth
# --------------------------------------------
# Generate with: openssl rand -hex 32
BETTER_AUTH_SECRET=""
BETTER_AUTH_URL="http://localhost:3000"

# --------------------------------------------
# App Config
# --------------------------------------------
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="Vertech Agents"
LOG_LEVEL="debug"

# --------------------------------------------
# Storage (S3-compatible → Supabase Storage)
# --------------------------------------------
S3_ENDPOINT="https://[ref].supabase.co/storage/v1/s3"
S3_REGION="sa-east-1"
S3_ACCESS_KEY_ID=""
S3_SECRET_ACCESS_KEY=""
NEXT_PUBLIC_AVATARS_BUCKET_NAME="avatars"
NEXT_PUBLIC_WHATSAPP_MEDIA_BUCKET_NAME="whatsapp-media"
NEXT_PUBLIC_KNOWLEDGE_BUCKET_NAME="knowledge"

# --------------------------------------------
# AI Providers
# --------------------------------------------
OPENAI_API_KEY=""
ANTHROPIC_API_KEY=""
GOOGLE_GENERATIVE_AI_API_KEY=""

# --------------------------------------------
# Mail
# --------------------------------------------
MAIL_HOST=""
MAIL_PORT=""
MAIL_USER=""
MAIL_PASS=""
RESEND_API_KEY=""

# --------------------------------------------
# Payments (AbacatePay — Phase 12)
# --------------------------------------------
ABACATEPAY_API_KEY=""
ABACATEPAY_WEBHOOK_SECRET=""

# --------------------------------------------
# WhatsApp (Evolution API — Phase 6)
# --------------------------------------------
EVOLUTION_API_URL=""
EVOLUTION_API_KEY=""
WHATSAPP_WEBHOOK_SECRET=""

# --------------------------------------------
# Google Calendar (Phase 11)
# --------------------------------------------
GOOGLE_OAUTH_CLIENT_ID=""
GOOGLE_OAUTH_CLIENT_SECRET=""
GOOGLE_OAUTH_REDIRECT_URI=""

# --------------------------------------------
# Redis / BullMQ (job queue — Phase 07A)
# --------------------------------------------
# Dev local: suba via Docker com `pnpm redis:start`
# Prod (Coolify): configurar container Redis e apontar aqui
#   (ver docs/infrastructure/redis.md - secao Coolify)
REDIS_URL="redis://localhost:6379"

# --------------------------------------------
# Observability
# --------------------------------------------
SENTRY_DSN=""
