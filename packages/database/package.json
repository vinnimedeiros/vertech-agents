{
	"dependencies": {
		"@paralleldrive/cuid2": "^2.2.2",
		"@repo/config": "workspace:*",
		"drizzle-orm": "^0.44.2",
		"drizzle-zod": "^0.7.1",
		"pg": "^8.16.0",
		"zod": "^3.25.55"
	},
	"devDependencies": {
		"@biomejs/biome": "1.9.4",
		"@repo/tsconfig": "workspace:*",
		"@types/node": "22.15.30",
		"@types/pg": "^8.11.10",
		"dotenv-cli": "^8.0.0",
		"drizzle-kit": "^0.31.1",
		"tsx": "^4.19.0"
	},
	"main": "./index.ts",
	"name": "@repo/database",
	"scripts": {
		"generate": "dotenv -c -e ../../.env.local -- drizzle-kit generate --config=./drizzle/drizzle.config.ts",
		"push": "dotenv -c -e ../../.env.local -- drizzle-kit push --config=./drizzle/drizzle.config.ts",
		"migrate": "dotenv -c -e ../../.env.local -- drizzle-kit migrate --config=./drizzle/drizzle.config.ts",
		"studio": "dotenv -c -e ../../.env.local -- drizzle-kit studio --config=./drizzle/drizzle.config.ts",
		"type-check": "tsc --noEmit",
		"seed:07a": "dotenv -c -e ../../.env.local -- tsx seeds/07a-agent-commercial.ts",
		"seed:link": "dotenv -c -e ../../.env.local -- tsx seeds/link-agent-to-whatsapp.ts",
		"seed:enable-ai": "dotenv -c -e ../../.env.local -- tsx seeds/enable-ai-on-conversation.ts"
	},
	"types": "./**/.tsx",
	"version": "0.0.0"
}
